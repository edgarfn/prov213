# Modelo de variáveis de ambiente. Copie para `.env` (dev) ou `.env.local`
# (dev, tem prioridade sobre `.env` no Next.js) e preencha com valores reais.
# NUNCA commite o arquivo `.env`/`.env.local`/`.env.production` — todos estão
# no .gitignore. Este arquivo (`.env.example`) é a única exceção, propositalmente
# sem nenhum segredo real, e existe para documentar o que é necessário.
#
# Também é usado pelo docker-compose.yml: ao rodar `docker compose up` a
# partir desta pasta, o Compose lê automaticamente um arquivo `.env` aqui e
# substitui as variáveis ${...} do compose por esses valores.

# ── PostgreSQL ────────────────────────────────────────────────────────────
# Usadas pelo serviço `postgres` do docker-compose.yml (que faz sua própria
# substituição de ${...} dentro do YAML). Mantenha-as em sincronia com o
# usuário/senha/banco embutidos no DATABASE_URL abaixo — o Next.js/Prisma não
# expandem ${...} dentro do valor de outra variável, por isso o DATABASE_URL
# precisa estar escrito por extenso, não como composição destas três.
POSTGRES_USER=prov213
POSTGRES_PASSWORD=troque-por-uma-senha-forte-e-unica
POSTGRES_DB=prov213

# String de conexão completa usada pelo Next.js/Prisma — deve conter os MESMOS
# valores de POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_DB acima, escritos por
# extenso. Em dev local (fora de Docker), o host é "localhost" na porta
# mapeada (5433); dentro do docker-compose, o serviço `app` já monta a URL
# internamente apontando para o host interno "prov213-db" — não precisa
# repetir esta variável no ambiente de produção via docker-compose.
DATABASE_URL="postgresql://prov213:troque-por-uma-senha-forte-e-unica@localhost:5433/prov213"

# ── NextAuth ───────────────────────────────────────────────────────────────
# EM PRODUÇÃO, troque para o domínio público real (ex.: "https://prov213.netstart.inf.br").
# Usado para montar todo redirect absoluto do servidor (login, logout, troca de
# serventia, e-mails de recuperação de senha) via lib/utils.ts::absoluteUrl() e
# internamente pelo NextAuth — se ficar "localhost" em produção (ex.: PM2 sem
# herdar este .env, ou docker-compose sem essa variável), esses links quebram
# para os usuários reais (já aconteceu — ver ecosystem.config.js e
# docker-entrypoint.sh, que agora avisam no log se isso ocorrer).
NEXTAUTH_URL="http://localhost:3000"
# Gere um valor novo com: openssl rand -base64 32
NEXTAUTH_SECRET=troque-por-um-segredo-gerado-com-openssl-rand--base64-32

UPLOAD_DIR="./uploads"

# ── Cloudflare Turnstile (captcha do login — Privacy by Design) ────────────
# Chaves de TESTE do próprio Cloudflare (sempre aprovam, sem chamada de rede):
# https://developers.cloudflare.com/turnstile/troubleshooting/testing/
NEXT_PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"
TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"
# Em produção, troque pelas chaves reais do seu site em
# https://dash.cloudflare.com/?to=/:account/turnstile

# ── SMTP (opcional em dev — deixe em branco e os links aparecem no console) ─
# SMTP_HOST=smtp.exemplo.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=noreply@exemplo.com
# SMTP_PASS=troque-pela-senha-real
# SMTP_FROM=noreply@exemplo.com

# ── Administração ────────────────────────────────────────────────────────
# Usado apenas pelo seed, para criar/promover o primeiro administrador.
# ADMIN_EMAIL=admin@exemplo.com
# ADMIN_TEMP_PASSWORD=SenhaProvisoria123!  # opcional; se omitido, gera aleatória

# ── Log técnico (lib/logger.ts — Pino) ─────────────────────────────────────
# Nível mínimo emitido: trace | debug | info | warn | error | fatal.
# Padrão se omitido: "debug" em dev, "info" em produção. Em produção os logs
# saem em JSON estruturado no stdout (capturado pelo Docker/PM2); em dev saem
# formatados via pino-pretty. Nunca contêm password/token/secret em claro —
# ver REDACT_PATHS e maskSensitive() em lib/logger.ts.
# LOG_LEVEL=info
