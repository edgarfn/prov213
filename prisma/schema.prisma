generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ClasseServentia {
  CLASSE_1
  CLASSE_2
  CLASSE_3
}

enum SubclasseServentia {
  A
  B
  C
  D
  E
  F
  G
  H
  I
  J
}

enum TipoSolucao {
  PROPRIA
  CONTRATADA
  COMPARTILHADA
  COLETIVA
}

enum TipoInfra {
  LOCAL
  NUVEM
  HIBRIDA
}

enum RolePapel {
  TITULAR
  RESPONSAVEL_TECNICO
  DPO
  COLABORADOR
  AUDITOR_LEITURA
  GESTOR_REGIONAL // Pode gerenciar N serventias (multi-tenant)
}

enum StatusRequisito {
  NAO_INICIADO
  EM_ANDAMENTO
  CONCLUIDO
  NAO_APLICAVEL
}

enum TipoEvidencia {
  DOCUMENTO
  CONTRATO
  PRINT
  LOG
  RELATORIO
  ATA
}

enum GravidadeIncidente {
  BAIXO
  MEDIO
  ALTO
  CRITICO
}

enum StatusIncidente {
  ABERTO
  EM_TRATAMENTO
  ENCERRADO
}

/// Taxonomia inspirada no NIST SP 800-61 / ISO 27035, adaptada aos termos do
/// Provimento — usada para categorizar e permitir análise estatística dos
/// incidentes registrados (nenhuma delas é normativa do Provimento em si).
enum CategoriaIncidente {
  ACESSO_NAO_AUTORIZADO
  MALWARE_RANSOMWARE
  VAZAMENTO_DADOS
  INDISPONIBILIDADE_DOS
  PHISHING_ENGENHARIA_SOCIAL
  FALHA_CONFIGURACAO
  PERDA_ROUBO_DISPOSITIVO
  FISICO
  OUTRO
}

enum ConformidadeTeste {
  INTEGRAL
  PARCIAL
  NAO_CONFORME
}

enum StatusProrrogacao {
  SOLICITADA
  DEFERIDA
  INDEFERIDA
}

/// Art. 21, §1º (Classe 1, análise simplificada) x §2º (Classes 2 e 3,
/// requerimento formal com elementos probatórios)
enum FluxoProrrogacao {
  SIMPLIFICADO
  FORMAL
}

/// Máquina de estados do processo de Recomendação Técnica e Decisão do
/// Controlador (ver model RecomendacaoTecnica). Estados terminais: REJEITADO,
/// RISCO_ACEITO_TEMPORARIO e CONCLUIDO.
enum StatusRecomendacao {
  RASCUNHO
  COMPLEMENTACAO_SOLICITADA
  AGUARDANDO_PARECER_DPO
  AGUARDANDO_DECISAO
  REJEITADO
  RISCO_ACEITO_TEMPORARIO
  APROVADO_AGUARDANDO_IMPLEMENTACAO
  EM_IMPLEMENTACAO
  AGUARDANDO_ACEITE
  AGUARDANDO_ATUALIZACAO_DOCUMENTOS
  CONCLUIDO
}

enum DecisaoControlador {
  APROVADO_INTEGRAL
  APROVADO_COM_CONDICOES
  APROVADO_IMPLANTACAO_FUTURA
  COMPLEMENTACAO_SOLICITADA
  REJEITADO
  RISCO_ACEITO_TEMPORARIO
  SUBSTITUIDO_EQUIVALENTE
}

// ─── NextAuth ─────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Usuários ─────────────────────────────────────────────────────────────────

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  emailVerified      DateTime?
  name               String?
  passwordHash       String?
  image              String?
  mfaEnabled         Boolean   @default(false)
  mfaSecret          String?
  mfaVerified        Boolean   @default(false)
  mustChangePassword Boolean   @default(false)
  isAdmin            Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  accounts                    Account[]
  sessions                    Session[]
  membros                     MembroServentia[]
  progressos                  ProgressoRequisito[]
  incidentesResponsavel       Incidente[]
  vulnerabilidadesResponsavel Vulnerabilidade[]
  auditLogs                   AuditLog[]
  passwordResets              PasswordResetToken[]
  recomendacoesResponsavelTecnico  RecomendacaoTecnica[] @relation("RT_ResponsavelTecnico")
  recomendacoesParecerDpo         RecomendacaoTecnica[] @relation("RT_ParecerDpo")
  recomendacoesDecisaoControlador RecomendacaoTecnica[] @relation("RT_DecisaoControlador")
  recomendacoesResponsavelExecucao RecomendacaoTecnica[] @relation("RT_ResponsavelExecucao")
  recomendacoesOrdemEmitidaPor    RecomendacaoTecnica[] @relation("RT_OrdemEmitidaPor")
  recomendacoesAceiteTecnico      RecomendacaoTecnica[] @relation("RT_AceiteTecnico")
  recomendacoesAceiteControlador  RecomendacaoTecnica[] @relation("RT_AceiteControlador")
}

// ─── Reset de senha ───────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Serventias ───────────────────────────────────────────────────────────────

model Serventia {
  id                       String              @id @default(cuid())
  nome                     String
  cns                      String              @unique
  cnpj                     String?
  municipio                String
  uf                       String
  classe                   ClasseServentia
  subclasse                SubclasseServentia?
  arrecadacaoSemestral     Float?
  tipoSolucao              TipoSolucao
  infra                    TipoInfra
  dataVigenciaNorma        DateTime
  responsavelTecnico       String?
  controladorDados         String?
  dpo                      String?
  /// Inativação lógica (nunca exclusão física — retenção de 5 anos, Art. 7º,
  /// IV). Serventia inativa bloqueia acesso operacional via
  /// requireServentiaMembro, mas todo o histórico permanece consultável e
  /// pode ser reativada a qualquer momento por um TITULAR.
  ativa                    Boolean             @default(true)
  /// @deprecated Substituído pela tabela `Prorrogacao` (histórico completo,
  /// teto de 90 dias validado e fluxo simplificado/formal por classe).
  /// Mantidos por 1 ciclo de release para compatibilidade; não usar em código novo.
  prorrogacaoAtiva         Boolean             @default(false)
  prorrogacaoJustificativa String?
  prorrogacaoNovaData      DateTime?
  onboardingConcluido      Boolean             @default(false)
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt

  membros           MembroServentia[]
  progressos        ProgressoRequisito[]
  incidentes        Incidente[]
  vulnerabilidades  Vulnerabilidade[]
  testesRestauracao TesteRestauracao[]
  declaracoes       Declaracao[]
  auditLogs         AuditLog[]
  prorrogacoes      Prorrogacao[]
  recomendacoesTecnicas   RecomendacaoTecnica[]
  recomendacaoSequenciais RecomendacaoSequencial[]
}

model MembroServentia {
  id          String    @id @default(cuid())
  userId      String
  serventiaId String
  papel       RolePapel @default(COLABORADOR)
  ativo       Boolean   @default(true)
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])
  serventia   Serventia @relation(fields: [serventiaId], references: [id])

  @@unique([userId, serventiaId])
}

// ─── Catálogo (seed) ──────────────────────────────────────────────────────────

model Etapa {
  id                 String @id @default(cuid())
  numero             Int    @unique
  titulo             String
  escopo             String @db.Text
  condicoesObjetivas String @db.Text

  requisitos  Requisito[]
  declaracoes Declaracao[]
}

model Requisito {
  id                  String               @id @default(cuid())
  etapaId             String
  codigo              String               @unique
  titulo              String
  descricaoNorma      String               @db.Text
  explicacaoLeigo     String               @db.Text
  articuloReferencia  String
  classesAplicaveis   ClasseServentia[]
  parametrosPorClasse Json?
  evidenciasExigidas  String[]
  obrigatorio         Boolean              @default(true)
  metaExcelencia      Boolean              @default(false)
  etapa               Etapa                @relation(fields: [etapaId], references: [id])
  progressos          ProgressoRequisito[]
}

// ─── Progresso por Serventia ──────────────────────────────────────────────────

model ProgressoRequisito {
  id                       String          @id @default(cuid())
  serventiaId              String
  requisitoId              String
  status                   StatusRequisito @default(NAO_INICIADO)
  responsavelId            String?
  dataConclusao            DateTime?
  observacoes              String?         @db.Text
  solucaoAdotada           String?         @db.Text
  /// Demonstração de equivalência funcional (Anexo IV, item VII, "c") — usada
  /// no Relatório Simplificado da Classe 1; opcional para as demais classes.
  demonstracaoEquivalencia String?         @db.Text
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  serventia                Serventia       @relation(fields: [serventiaId], references: [id])
  requisito                Requisito       @relation(fields: [requisitoId], references: [id])
  responsavel              User?           @relation(fields: [responsavelId], references: [id])
  evidencias               Evidencia[]

  @@unique([serventiaId, requisitoId])
}

// ─── Evidências ───────────────────────────────────────────────────────────────

/// Vinculada a exatamente uma origem: um ProgressoRequisito (dossiê do
/// checklist), um TesteRestauracao (Anexo V), um Incidente, uma
/// Vulnerabilidade ou uma RecomendacaoTecnica — nunca mais de uma, nunca
/// nenhuma (reforçado por CHECK constraint no banco; ver migration
/// correspondente).
model Evidencia {
  id                     String              @id @default(cuid())
  progressoRequisitoId   String?
  testeRestauracaoId     String?
  incidenteId            String?
  vulnerabilidadeId      String?
  recomendacaoTecnicaId  String?
  nomeArquivo          String
  storagePath          String
  hashSha256           String
  tamanhoBytes         Int
  tipo                 TipoEvidencia       @default(DOCUMENTO)
  uploadedBy           String
  uploadedAt           DateTime            @default(now())
  deletedAt            DateTime?
  progressoRequisito   ProgressoRequisito?  @relation(fields: [progressoRequisitoId], references: [id])
  testeRestauracao     TesteRestauracao?    @relation(fields: [testeRestauracaoId], references: [id])
  incidente            Incidente?           @relation(fields: [incidenteId], references: [id])
  vulnerabilidade      Vulnerabilidade?     @relation(fields: [vulnerabilidadeId], references: [id])
  recomendacaoTecnica  RecomendacaoTecnica? @relation(fields: [recomendacaoTecnicaId], references: [id])

  @@index([testeRestauracaoId])
  @@index([incidenteId])
  @@index([vulnerabilidadeId])
  @@index([recomendacaoTecnicaId])
}

// ─── Incidentes ───────────────────────────────────────────────────────────────

model Incidente {
  id                          String             @id @default(cuid())
  serventiaId                 String
  titulo                      String
  descricao                   String             @db.Text
  categoria                   CategoriaIncidente @default(OUTRO)
  dataOcorrencia              DateTime
  dataCiencia                 DateTime
  gravidade                   GravidadeIncidente
  status                      StatusIncidente    @default(ABERTO)
  responsavelId               String?
  comunicadoCorregedoria      Boolean            @default(false)
  dataComunicacao             DateTime?
  comunicadoAnpd              Boolean            @default(false)
  causaRaiz                   String?            @db.Text
  medidasCorretivas           String?            @db.Text
  /// Art. 48 da LGPD / Resolução CD/ANPD nº 15/2024 — informações mínimas
  /// exigidas na comunicação de incidente com dados pessoais à ANPD.
  dadosPessoaisEnvolvidos     Boolean            @default(false)
  categoriasDadosAfetados     String?            @db.Text
  quantidadeTitularesAfetados Int?
  riscosTitulares             String?            @db.Text
  createdAt                   DateTime           @default(now())
  updatedAt                   DateTime           @updatedAt
  serventia                   Serventia          @relation(fields: [serventiaId], references: [id])
  responsavel                 User?              @relation(fields: [responsavelId], references: [id])
  evidencias                  Evidencia[]
}

// ─── Vulnerabilidades ─────────────────────────────────────────────────────────

enum ClassificacaoRisco {
  BAIXO
  MEDIO
  ALTO
  CRITICO
}

/// Fluxo de tratamento inspirado em NIST SP 800-40 / ISO 27001 A.12.6.1
/// (registro de vulnerabilidades técnicas). RISCO_ACEITO e FALSO_POSITIVO
/// também encerram o prazo (ver dataEncerramento), mas exigem justificativa.
enum StatusVulnerabilidade {
  IDENTIFICADA
  EM_CORRECAO
  CORRIGIDA
  RISCO_ACEITO
  FALSO_POSITIVO
}

enum OrigemVulnerabilidade {
  PENTESTE
  SCANNER_AUTOMATIZADO
  REPORTE_INTERNO
  REPORTE_EXTERNO
  AUDITORIA
  FORNECEDOR_CVE
  OUTRO
}

model Vulnerabilidade {
  id                       String                @id @default(cuid())
  serventiaId              String
  descricao                String                @db.Text
  dataIdentificacao        DateTime
  classificacaoRisco       ClassificacaoRisco
  status                   StatusVulnerabilidade @default(IDENTIFICADA)
  origem                   OrigemVulnerabilidade @default(OUTRO)
  ativoAfetado             String?
  /// Referência externa (ex.: CVE-2025-12345), quando aplicável
  cveReferencia            String?
  /// CVSS v3.1 (0.0–10.0) — usado só para sugerir a classificação de risco
  cvssScore                Float?
  responsavelId            String?
  exploracaoAtiva          Boolean               @default(false)
  prazoLimite              DateTime
  dataEncerramento         DateTime?
  providencias             String?               @db.Text
  /// Exigida quando status = RISCO_ACEITO (aceite formal de risco)
  justificativaRiscoAceito String?               @db.Text
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  serventia                Serventia             @relation(fields: [serventiaId], references: [id])
  responsavel              User?                 @relation(fields: [responsavelId], references: [id])
  evidencias               Evidencia[]
}

// ─── Testes de Restauração ────────────────────────────────────────────────────

model TesteRestauracao {
  id                  String            @id @default(cuid())
  serventiaId         String
  dataTeste           DateTime
  sistemasRestaurados String[]
  rtoAferido          Float
  rtoDefinido         Float
  rpoAferido          Float
  rpoDefinido         Float
  conformidade        ConformidadeTeste
  participantes       Json?
  arquiteturaBackup   Json?
  /// Anexo V, item 8 — providências deliberadas quando a conformidade não é integral
  medidasCorretivas   String?           @db.Text
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  serventia           Serventia         @relation(fields: [serventiaId], references: [id])
  evidencias          Evidencia[]
}

// ─── Declarações ──────────────────────────────────────────────────────────────

model Declaracao {
  id                String    @id @default(cuid())
  serventiaId       String
  etapaId           String
  dataDeclaracao    DateTime  @default(now())
  declarante        String
  arquivoDeclaracao String?
  serventia         Serventia @relation(fields: [serventiaId], references: [id])
  etapa             Etapa     @relation(fields: [etapaId], references: [id])

  @@unique([serventiaId, etapaId])
}

// ─── Prorrogação de prazo (Art. 21) ───────────────────────────────────────────

/// Histórico de pedidos de prorrogação do prazo do Art. 20 (Etapas 1 e 2),
/// de até 90 dias, uma única vez. Substitui os campos soltos
/// `Serventia.prorrogacaoAtiva/prorrogacaoJustificativa/prorrogacaoNovaData`.
model Prorrogacao {
  id                   String            @id @default(cuid())
  serventiaId          String
  /// Único valor usado hoje: 'ETAPAS_1_2' (Art. 21 só prorroga o prazo do Art. 20)
  tipoPrazo            String
  dataOriginal         DateTime
  dataSolicitada       DateTime
  fluxo                FluxoProrrogacao
  justificativa        String            @db.Text
  /// Obrigatório quando `fluxo = FORMAL` (Classes 2 e 3, Art. 21, §2º)
  elementosProbatorios String?           @db.Text
  status               StatusProrrogacao @default(SOLICITADA)
  solicitadoPor        String
  dataSolicitacao      DateTime          @default(now())
  decididoPor          String?
  dataDecisao          DateTime?
  observacoesDecisao   String?           @db.Text
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  serventia            Serventia         @relation(fields: [serventiaId], references: [id])

  @@index([serventiaId, status])
}

// ─── Recomendação Técnica e Decisão do Controlador ────────────────────────────
// Processo de governança de TI/LGPD em 8 etapas: Recomendação Técnica →
// Análise de Risco → Parecer do DPO (se envolver dados pessoais) → Decisão
// formal do Controlador → Ordem de Implementação → Execução/Evidências →
// Teste e Aceite → Atualização dos documentos de governança. Alimenta como
// evidência os Requisitos 1.1, 1.2, 1.4, 1.8, 2.5 e 4.3 do seed.

model RecomendacaoTecnica {
  id            String @id @default(cuid())
  serventiaId   String
  /// Código legível RT-{CNS}-{ANO}-{SEQ}, ex.: RT-12345-2026-001
  codigo        String @unique
  anoReferencia Int
  sequencial    Int

  status                  StatusRecomendacao @default(RASCUNHO)
  /// Etapa 1 — prioridade declarada na recomendação
  prioridade              ClassificacaoRisco
  /// Etapa 2 — classificação de risco resultante da análise
  classificacaoRiscoFinal ClassificacaoRisco?
  /// Etapa 2 — determina se a Etapa 3 (Parecer do DPO) é exigida
  envolveDadosPessoais    Boolean            @default(false)

  dataIdentificacao    DateTime
  /// Prazo recomendado na Etapa 1 (informativo; alimenta alerta de semáforo)
  prazoRecomendado     DateTime?
  responsavelTecnicoId String

  /// Etapa 1 (GOV-TI-01): situacaoAtual, problemaDeficiencia, requisitoRelacionado,
  /// ativoAfetado, riscoNaoImplementar, solucaoRecomendada, alternativasPossiveis,
  /// estimativaCusto, evidenciasColetadasObs
  recomendacao Json

  /// Etapa 2 (GOV-TI-02): probabilidadeOcorrencia, impactoOperacional,
  /// impactoDadosPessoais, impactoAcervoRegistral, impactoFinanceiro,
  /// impactoJuridicoCorrecional, controlesExistentes, controlesRecomendados,
  /// riscoResidualAposImplementacao, consequenciaRejeicao, relacaoPcnPrd, relacaoRpoRto
  analiseRisco Json?

  /// Preenchido com o autor no momento do registro (gate já garante papel DPO)
  parecerDpoUserId      String?
  parecerDpoConcluidoEm DateTime?
  /// Etapa 3 (GOV-TI-03): necessidadeProporcionalidade, dadosSensiveisEnvolvidos,
  /// novosFornecedores, acessosRemotos, armazenamentoNuvem, transferenciaInternacional,
  /// logsMonitoramento, retencao, contratosOperadores, riscoTitulares,
  /// necessidadeRipd, necessidadeAtualizarRopa, conclusao
  parecerDpo            Json?

  decisao                  DecisaoControlador?
  /// Preenchido com o autor no momento da decisão (gate já garante papel TITULAR)
  decisaoControladorUserId String?
  dataDecisao              DateTime?
  valorAutorizado          Float?
  /// Usado em alerta de semáforo enquanto status = APROVADO_AGUARDANDO_IMPLEMENTACAO/EM_IMPLEMENTACAO
  prazoImplantacao         DateTime?
  responsavelExecucaoId    String?
  /// Etapa 4: fonteOrcamentaria, condicoesImpostas, riscoResidualConhecido
  decisaoDetalhes          Json?

  /// Usado em alerta de semáforo enquanto status = RISCO_ACEITO_TEMPORARIO
  prazoReavaliacao DateTime?
  /// GOV-TI-09 (obrigatório quando decisao IN (REJEITADO, RISCO_ACEITO_TEMPORARIO)):
  /// fundamentoTecnico, consequenciasRejeicao, alternativasApresentadas,
  /// motivoDeclarado, medidasCompensatorias
  termoCiencia     Json?

  dataExecucaoPlanejada DateTime?
  ordemEmitidaPorUserId String?
  ordemEmitidaEm        DateTime?
  /// Etapa 5 (GOV-TI-05): escopoAprovado, equipamentosServicos, responsaveis,
  /// planoRollback, riscosMudanca, backupAnterior, criteriosSucesso,
  /// testesObrigatorios, indisponibilidadePrevista, comunicacaoColaboradores,
  /// autorizacaoAcessoPrivilegiado
  ordemImplementacao    Json?

  dataExecucaoRealizada DateTime?
  /// Etapa 6 (GOV-TI-06): relatorioTecnico, configuracaoAnterior, configuracaoPosterior,
  /// usuariosExecutores, resultadosTestes, falhas, medidasCorretivas
  /// (evidências reais em anexo via relação Evidencia, não aqui)
  execucao              Json?

  aceiteResultado         ConformidadeTeste?
  aceiteTecnicoUserId     String?
  /// Deve ser membro ativo com papel TITULAR (validado na action)
  aceiteControladorUserId String?
  dataAceite              DateTime?
  /// Etapa 7 (GOV-TI-07): requisitoAtendido, testesRealizados, resultadoObtido,
  /// pendencias, riscoResidual
  aceite                  Json?

  documentosAtualizadosEm DateTime?
  /// Etapa 8 (GOV-TI-10): checklist (inventarioAtivos, diagramaRede, pcn, prd,
  /// psi, ropa, matrizRiscos, planoBackup, dossieTecnico, outros)
  documentosAtualizados   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  serventia           Serventia @relation(fields: [serventiaId], references: [id])
  responsavelTecnico  User      @relation("RT_ResponsavelTecnico", fields: [responsavelTecnicoId], references: [id])
  parecerDpoUser      User?     @relation("RT_ParecerDpo", fields: [parecerDpoUserId], references: [id])
  decisaoControlador  User?     @relation("RT_DecisaoControlador", fields: [decisaoControladorUserId], references: [id])
  responsavelExecucao User?     @relation("RT_ResponsavelExecucao", fields: [responsavelExecucaoId], references: [id])
  ordemEmitidaPor     User?     @relation("RT_OrdemEmitidaPor", fields: [ordemEmitidaPorUserId], references: [id])
  aceiteTecnico       User?     @relation("RT_AceiteTecnico", fields: [aceiteTecnicoUserId], references: [id])
  aceiteControlador   User?     @relation("RT_AceiteControlador", fields: [aceiteControladorUserId], references: [id])
  evidencias          Evidencia[]

  @@unique([serventiaId, anoReferencia, sequencial])
  @@index([serventiaId, status])
}

/// Contador atômico por serventia/ano para o código RT-{CNS}-{ANO}-{SEQ}
/// (ver lib/recomendacao-tecnica.ts::proximoCodigoRecomendacao).
model RecomendacaoSequencial {
  serventiaId  String
  ano          Int
  ultimoNumero Int       @default(0)
  serventia    Serventia @relation(fields: [serventiaId], references: [id])

  @@id([serventiaId, ano])
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id              String     @id @default(cuid())
  serventiaId     String?
  userId          String?
  // Desnormalizado para resiliência: mantém identidade mesmo se o usuário for excluído
  userEmail       String?
  userName        String?
  acao            String // ex: LOGIN_SUCESSO, UPLOAD, DECLARAR_CONCLUSAO
  entidade        String // ex: User, Evidencia, Etapa
  entidadeId      String?
  valorAnterior   Json? // dados ANTES da operação (dados sensíveis mascarados)
  valorNovo       Json? // dados APÓS a operação (dados sensíveis mascarados)
  timestamp       DateTime   @default(now())
  ipAddress       String?
  userAgent       String?
  // Hash SHA-256 formando cadeia de integridade (tamper-evident log chain)
  hashIntegridade String?
  serventia       Serventia? @relation(fields: [serventiaId], references: [id])
  user            User?      @relation(fields: [userId], references: [id])

  @@index([serventiaId, timestamp])
  @@index([userId])
  @@index([acao])
}
